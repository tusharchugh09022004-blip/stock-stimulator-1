API_KEY=your_alphavantage_api_key_here
PORT=5000
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRY=7d
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id

# Database (PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@localhost:5432/stocksim

# Market Data Feed Configuration
# Options: simulated, dhan, upstox, angel
MARKET_BROKER=simulated

# Dhan API Credentials
DHAN_API_KEY=
DHAN_CLIENT_ID=

# Upstox API Credentials
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:5000/auth/upstox/callback
UPSTOX_ACCESS_TOKEN=

# Client URL (for CORS and OAuth redirects)
CLIENT_URL=http://localhost:5173

# Angel One API Credentials
ANGEL_CLIENT_CODE=
ANGEL_API_KEY=
ANGEL_ACCESS_TOKEN=
ANGEL_FEED_TOKEN=

